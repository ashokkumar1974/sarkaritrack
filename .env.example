# ============================================================
# SarkariTrack — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (Required) ──────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/sarkaritrack"

# ── Redis / Upstash (Required for caching) ───────────────────
UPSTASH_REDIS_REST_URL="https://xxxxxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxx"

# ── App URLs (Required) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://sarkaritrack.in"
API_BASE_URL="https://api.sarkaritrack.in"
NEXTJS_URL="https://sarkaritrack.in"

# ── Internal Security (Required) ─────────────────────────────
INTERNAL_API_KEY="change-this-to-a-long-random-string-min-32-chars"
NEXTJS_REVALIDATE_SECRET="another-random-string-for-cache-revalidation"

# ── AI Models (At least one required for PDF parsing) ────────
OPENAI_API_KEY="sk-..."
# OR
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="gpt-4o"

# ── Web Push Notifications (Optional) ────────────────────────
# Generate with: cd apps/web && npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_PRIVATE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_CONTACT="mailto:admin@sarkaritrack.in"

# ── Telegram (Optional) ───────────────────────────────────────
# Get from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN="1234567890:AAxxxxxxxxxxxxxxxx"
TELEGRAM_CHANNEL_ID="@sarkaritrack"
TELEGRAM_ADMIN_CHAT_ID="987654321"

# ── WhatsApp Cloud API (Optional) ────────────────────────────
# Get from: developers.facebook.com
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_CHANNEL_NUMBER="+91xxxxxxxxxx"

# ── Analytics (Optional) ──────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Environment ───────────────────────────────────────────────
NODE_ENV="development"
